{
  "action_contracts_path": "actions.yaml",
  "artifacts": {
    "actions": "actions.yaml",
    "agent": "agent.md",
    "architecture": "architecture.svg",
    "output_contract": "output-contract.md",
    "runtime_contract": "agent.manifest.json",
    "runtime_setup": "endorctl-setup.md"
  },
  "data_gap_policy": "Record unavailable transport, credential, adapter, runtime, or evidence signals in data_gaps instead of fabricating evidence.",
  "declared_actions": [
    {
      "availability": "available",
      "confirmation_required": false,
      "id": "resolve-endor-project",
      "inputs": [
        "repository_url",
        "repo_full_name",
        "project_name",
        "namespace"
      ],
      "kind": "endor.query",
      "outputs": [
        "project_uuid",
        "project_name",
        "repo_full_name",
        "namespace",
        "namespace_provenance"
      ],
      "portable_kind": "endor.query",
      "safety_class": "read_only",
      "source_provider_examples": [
        "endorctl-api",
        "endor-api"
      ]
    },
    {
      "availability": "available",
      "confirmation_required": false,
      "id": "fetch-pinned-source",
      "inputs": [
        "repo",
        "finding_uuid",
        "source_sha",
        "file_path",
        "data_flow_anchors",
        "exploit_reproduction",
        "remediation_guidance"
      ],
      "kind": "scm.source_read",
      "outputs": [
        "source_text",
        "source_sha",
        "source_url",
        "source_location_provenance"
      ],
      "portable_kind": "repository.read",
      "safety_class": "read_only",
      "source_provider_examples": [
        "local-git",
        "gh-cli",
        "glab-cli",
        "github",
        "gitlab"
      ]
    },
    {
      "availability": "available",
      "confirmation_required": true,
      "id": "open-change-request",
      "inputs": [
        "repo",
        "base_branch",
        "patch_diff",
        "title",
        "body",
        "exploit_context",
        "remediation_guidance_usage",
        "validation_plan",
        "existing_change_request_check"
      ],
      "kind": "scm.change_request",
      "outputs": [
        "url",
        "branch",
        "status",
        "title",
        "body",
        "existing_change_request_check"
      ],
      "portable_kind": "source.change_request.create",
      "safety_class": "mutating",
      "source_provider_examples": [
        "local-git",
        "gh-cli",
        "glab-cli",
        "github",
        "gitlab"
      ]
    },
    {
      "availability": "available",
      "confirmation_required": true,
      "id": "request-exception-review",
      "inputs": [
        "finding_uuid",
        "request_type",
        "request_comment",
        "expiration_time",
        "pr_url",
        "approver_instructions"
      ],
      "kind": "approval.request",
      "outputs": [
        "approval_request_url",
        "status"
      ],
      "portable_kind": "approval.request",
      "safety_class": "mutating",
      "source_provider_examples": [
        "github-pr-comment",
        "github-pr-review",
        "gitlab-mr-note",
        "gitlab-approval"
      ]
    },
    {
      "availability": "available",
      "confirmation_required": false,
      "id": "verify-appsec-approval",
      "inputs": [
        "pr_url",
        "finding_uuid",
        "request_type",
        "allowed_approvers",
        "approval_phrase"
      ],
      "kind": "approval.verify",
      "outputs": [
        "approved",
        "approver",
        "approval_evidence_url",
        "approved_at"
      ],
      "portable_kind": "approval.verify",
      "safety_class": "read_only",
      "source_provider_examples": [
        "gh-cli",
        "glab-cli",
        "github-api",
        "gitlab-api"
      ]
    },
    {
      "availability": "available",
      "confirmation_required": true,
      "id": "write-exception-policy",
      "inputs": [
        "finding_uuid",
        "project_uuid",
        "policy_name",
        "exception_reason",
        "expiration_time",
        "approver",
        "approval_evidence_url",
        "idempotency_check"
      ],
      "kind": "endor.policy_write",
      "outputs": [
        "policy_name",
        "policy_uuid",
        "status",
        "idempotency_status"
      ],
      "portable_kind": "endor.policy.write",
      "safety_class": "mutating",
      "source_provider_examples": [
        "endorctl-api",
        "endor-api"
      ]
    },
    {
      "availability": "available",
      "confirmation_required": true,
      "id": "post-decision-comment",
      "inputs": [
        "pr_url",
        "decision",
        "policy_name",
        "policy_uuid",
        "body"
      ],
      "kind": "scm.comment",
      "outputs": [
        "comment_url",
        "status"
      ],
      "portable_kind": "source.comment.create",
      "safety_class": "mutating",
      "source_provider_examples": [
        "github",
        "gitlab"
      ]
    }
  ],
  "degradation": {
    "missing_capability_behavior": "record_data_gap",
    "mutation_without_adapter": "forbidden",
    "supports_plan_only": true
  },
  "description": "Parse Endor AI SAST findings, use exploit reproduction and remediation guidance as patch context, fetch source at the pinned commit, and open change requests when requested.",
  "endorctl_api_invocations": [
    "resolve_project_from_repository",
    "list_ai_sast_findings",
    "get_finding_explanation",
    "fetch_project_source_version",
    "create_scoped_exception_policy"
  ],
  "generated_files_are_editable": false,
  "id": "ai-sast-triage",
  "inputs": [
    {
      "description": "Optional human project selector such as owner/repo, repository name, Endor project name, or repository URL. The agent should infer this from the current Git workspace first, not ask the user for a project UUID.",
      "kind": "string",
      "name": "project_name",
      "required": false
    },
    {
      "description": "Optional source repository URL when the agent is not running inside the target repository. Normally inferred from git remote origin.",
      "kind": "string",
      "name": "repository_url",
      "required": false
    },
    {
      "description": "Maximum AI SAST findings to triage after project resolution.",
      "kind": "integer",
      "name": "finding_limit",
      "required": false
    },
    {
      "description": "Optional Endor severity filter such as CRITICAL or HIGH.",
      "kind": "list[string]",
      "name": "severity_filter",
      "required": false
    },
    {
      "description": "Optional CWE filter such as CWE-79.",
      "kind": "list[string]",
      "name": "cwe_filter",
      "required": false
    },
    {
      "description": "Optional finding UUID allow-list for targeted re-triage. Do not require this for normal use.",
      "kind": "list[string]",
      "name": "finding_uuids",
      "required": false
    },
    {
      "description": "Optional Endor namespace override when the tenant uses child namespaces.",
      "kind": "string",
      "name": "namespace",
      "required": false
    },
    {
      "description": "Optional source-provider handles or team slugs allowed to approve standalone exception-policy creation.",
      "kind": "list[string]",
      "name": "appsec_approvers",
      "required": false
    }
  ],
  "name": "AI SAST Triage",
  "outputs": [
    {
      "description": "Triage summary including confirmed TPs, likely FPs, inconclusive findings, exploit-driven priority, remediation-guidance usage, patches ready, and PR/MR counters.",
      "kind": "string",
      "name": "summary",
      "required": true
    },
    {
      "description": "Resolved Endor project and namespace evidence, including project_uuid, namespace, namespace_provenance, repo_full_name, and attempted selectors.",
      "kind": "object",
      "name": "project_resolution",
      "required": true
    },
    {
      "description": "Per-finding parsed AI SAST classification, finding UUID, source-location provenance, scorecard evidence, severity scoring, data-flow anchors, exploit reproduction, remediation guidance, priority rationale, and deterministic skip reason when applicable.",
      "kind": "list[object]",
      "name": "verdicts",
      "required": true
    },
    {
      "description": "Generated unified diffs with confidence, patch reason, remediation guidance used or rejected, exploit-informed validation plan, sibling-file references, source SHA, branch name, and rendered PR/MR body for TRUE_POSITIVE findings with source context.",
      "kind": "list[object]",
      "name": "patches",
      "required": true
    },
    {
      "description": "PR/MR URLs, branches, status, failure reason, and existing_change_request_check evidence for any requested change-request creation.",
      "kind": "list[object]",
      "name": "change_requests",
      "required": true
    },
    {
      "description": "Verified AppSec approval evidence for exception requests, including approver, evidence URL, status, and data gaps.",
      "kind": "list[object]",
      "name": "approvals",
      "required": true
    },
    {
      "description": "Endor exception policies created or reused after verified AppSec approval, including policy name, policy UUID, idempotency check, human-readable project scope, expiration, decision comment, and approval evidence URL.",
      "kind": "list[object]",
      "name": "exception_policies",
      "required": true
    },
    {
      "description": "Missing Endor, source, or host signals.",
      "kind": "list[string]",
      "name": "data_gaps",
      "required": true
    }
  ],
  "portable_schema_version": 1,
  "recipe_schema_version": 2,
  "required_capabilities": [
    "approval.request",
    "approval.verify",
    "endor.policy.write",
    "endor.query",
    "repository.patch.prepare",
    "repository.read",
    "source.change_request.create",
    "source.change_request.lookup",
    "source.comment.create"
  ],
  "required_endor_mcp_tools": [],
  "required_transports": [
    "endorctl_api"
  ],
  "requires_endor_mcp": "",
  "requires_endorctl": ">=1.0",
  "runtime_action_vocabulary": [
    {
      "confirmation_required": false,
      "declared_by_recipe": true,
      "description": "Run read-only Endor evidence lookups through an approved Endor transport.",
      "kind": "endor.query",
      "provider_examples": [
        "endor-api",
        "endorctl-api",
        "approved-endor-mcp-adapter"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": false,
      "declared_by_recipe": true,
      "description": "Read repository files, manifests, lockfiles, or pinned source context.",
      "kind": "repository.read",
      "provider_examples": [
        "repository-service",
        "source-index",
        "local-checkout"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": false,
      "declared_by_recipe": true,
      "description": "Prepare or apply a repository patch after explicit approval.",
      "kind": "repository.patch.prepare",
      "provider_examples": [
        "patch-service",
        "dependency-update-service",
        "local-checkout"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": false,
      "declared_by_recipe": true,
      "description": "Look up existing branches, pull requests, merge requests, or internal change records.",
      "kind": "source.change_request.lookup",
      "provider_examples": [
        "github",
        "gitlab",
        "bitbucket",
        "internal-change-service"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": true,
      "declared_by_recipe": true,
      "description": "Create or update a source-provider change request after explicit approval.",
      "kind": "source.change_request.create",
      "provider_examples": [
        "github",
        "gitlab",
        "bitbucket",
        "internal-change-service"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": true,
      "declared_by_recipe": true,
      "description": "Post or update a source-provider comment after explicit approval.",
      "kind": "source.comment.create",
      "provider_examples": [
        "github",
        "gitlab",
        "bitbucket",
        "internal-change-service"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": true,
      "declared_by_recipe": true,
      "description": "Request approval through the runtime's approved review workflow.",
      "kind": "approval.request",
      "provider_examples": [
        "appsec-review-service",
        "source-review-api",
        "internal-approval-service"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": false,
      "declared_by_recipe": true,
      "description": "Verify approval evidence before a gated action proceeds.",
      "kind": "approval.verify",
      "provider_examples": [
        "appsec-review-service",
        "source-review-api",
        "internal-approval-service"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": true,
      "declared_by_recipe": true,
      "description": "Create or reuse an Endor policy only after required approval and confirmation.",
      "kind": "endor.policy.write",
      "provider_examples": [
        "endor-api",
        "endorctl-api"
      ],
      "status": "declared"
    },
    {
      "confirmation_required": true,
      "declared_by_recipe": false,
      "description": "Create a ticket from final agent output through a runtime wrapper or declared action.",
      "kind": "ticket.create",
      "provider_examples": [
        "jira",
        "servicenow",
        "linear",
        "internal-ticketing"
      ],
      "status": "wrapper_available"
    }
  ],
  "runtime_wrappers": [
    {
      "confirmation_required": true,
      "declared_by_recipe": false,
      "kind": "ticket.create",
      "provider_examples": [
        "jira",
        "servicenow",
        "linear",
        "internal-ticketing"
      ],
      "status": "wrapper_available"
    }
  ],
  "safety_class": "mutating",
  "version": "0.1.0"
}
