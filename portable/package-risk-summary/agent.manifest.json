  "data_gap_policy": "Record unavailable transport, credential, adapter, runtime, or evidence signals in data_gaps instead of fabricating evidence.",
  "declared_actions": [],
  "degradation": {
    "missing_capability_behavior": "record_data_gap",
    "mutation_without_adapter": "forbidden",
    "supports_plan_only": true
  },
  "description": "Use this agent when the user wants a concise risk profile for a specific\npackage version without asking for a yes/no dependency decision. Examples:\n\"Summarize npm lodash 4.17.20 risk\", \"Give me the risk picture for\nlog4j-core 2.14.1\", \"What should I know about this package version before I\nreview it?\" Returns an evidence-backed package risk summary with\nvulnerabilities, malware or typosquat signals, package scores, license notes,\nrecommended next checks, and any data gaps.\n",
  "endorctl_api_invocations": [
    "lookup_package_version_uuid",
    "get_package_scores",
    "get_package_license",
    "query_similar_packages"
  ],
  "generated_files_are_editable": false,
  "id": "package-risk-summary",
  "inputs": [
    {
      "description": "Package ecosystem, such as npm, pypi, maven, go, cargo, gem, nuget, or packagist.",
      "kind": "string",
      "name": "ecosystem",
      "required": true
    },
    {
      "description": "Exact package name as it appears in a manifest.",
      "kind": "string",
      "name": "package_name",
      "required": true
    },
    {
      "description": "Exact package version to summarize.",
      "kind": "string",
      "name": "version",
      "required": true
    }
  ],
  "name": "Endor Labs Package Risk Summary",
  "outputs": [
    {
      "description": "LOW, MODERATE, HIGH, CRITICAL, or UNKNOWN.",
      "kind": "enum",
      "name": "risk_posture",
      "required": true
    },
    {
      "description": "Evidence-backed vulnerability, malware, typosquat, score, or license findings.",
      "kind": "list[string]",
      "name": "findings",
      "required": true
    },
    {
      "description": "Positive evidence such as clean risk checks, good scores, or known safe alternatives.",
      "kind": "list[string]",
      "name": "strengths",
      "required": true
    },
    {
      "description": "Follow-up checks, review areas, or upgrade/remediation actions.",
      "kind": "list[string]",
      "name": "next_checks",
      "required": true
    },
    {
      "description": "One-paragraph human-readable assessment.",
      "kind": "string",
      "name": "summary",
      "required": true
    },
    {
      "description": "Signals that were unavailable because setup, auth, edition, or tooling was missing.",
      "kind": "list[string]",
      "name": "data_gaps",
      "required": true
    }
  ],
  "portable_schema_version": 1,
  "recipe_schema_version": 1,
  "required_capabilities": [
    "endor.query"
  ],
  "required_endor_mcp_tools": [
    "check_dependency_for_risks",
    "check_dependency_for_vulnerabilities",
    "get_endor_vulnerability"
  ],
  "required_transports": [
    "mcp",
    "endorctl_api"
  ],
  "requires_endor_mcp": ">=2.4",
  "requires_endorctl": ">=1.0",
